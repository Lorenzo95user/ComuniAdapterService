<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 1. Proprietà: dove salvare i log e come chiamarli -->
    <property name="LOGS" value="./logs" />
    <property name="APP_NAME" value="territory-data-api" />

    <!-- 2. Appender per la CONSOLE (con colori) -->
    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>
                %d{yyyy-MM-dd HH:mm:ss} %highlight(%-5level) [%blue(%t)] %yellow(%C{1}): %msg%n
            </Pattern>
        </layout>
    </appender>

    <!-- 3. Appender per il FILE (con rotazione automatica) -->
    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS}/${APP_NAME}.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <Pattern>%d %p %C{1} [%t] %m%n</Pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Crea un nuovo file ogni giorno o quando supera i 10MB -->
            <fileNamePattern>${LOGS}/archived/${APP_NAME}-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory> <!-- Tiene i log per 30 giorni -->
            <totalSizeCap>1GB</totalSizeCap> <!-- Non superare mai 1GB totale di archivio -->
        </rollingPolicy>
    </appender>

    <!-- 4. LOG LEVEL personalizzati -->
    
    <!-- Log generali di Spring (solo errori e info importanti) -->
    <root level="INFO">
        <appender-ref ref="RollingFile" />
        <appender-ref ref="Console" />
    </root>

    <!-- I TUOI LOG (impostati a DEBUG per vedere tutto il flusso) -->
    <logger name="it.newtech.project" level="DEBUG" additivity="false">
        <appender-ref ref="RollingFile" />
        <appender-ref ref="Console" />
    </logger>

</configuration>
